        { name: "Three of Pentacles", description: "《金币三》描绘了工匠的工作，代表着团队合作。", upright: "团队合作、工艺", reversed: "缺乏团队精神", easternWisdom: "金币三与道家'无用'相契合，提醒我们重视团队协作的力量。", keywords: ["团队", "工艺", "合作"] },
        { name: "Four of Pentacles", description: "《金币四》描绘了保护的姿态，代表着安全和控制。", upright: "安全、控制、占有", reversed: "慷慨、放手", easternWisdom: "金币四与佛教'布施'相契合，教会我们学会分享和放手。", keywords: ["安全", "控制", "占有"] },
        { name: "Five of Pentacles", description: "《金币五》描绘了困难的时期，代表着孤立和困难。", upright: "困难时期、孤立", reversed: "恢复、希望", easternWisdom: "金币五与易经'蹇'卦相契合，提醒我们在困难中保持希望。", keywords: ["困难", "孤立", "希望"] },
        { name: "Six of Pentacles", description: "《金币六》描绘了分享的场景，代表着慈善和平衡。", upright: "分享、慈善、平衡", reversed: "自私、债务", easternWisdom: "金币六与儒家'仁者爱人'相契合，代表着分享和慈悲的精神。", keywords: ["分享", "慈善", "平衡"] },
        { name: "Seven of Pentacles", description: "《金币七》描绘了等待和投资，代表着耐心。", upright: "耐心、等待、长期投资", reversed: "缺乏耐心、提前收获", easternWisdom: "金币七与易经'升'卦相契合，提醒我们要耐心等待收获。", keywords: ["耐心", "等待", "投资"] },
        { name: "Eight of Pentacles", description: "《金币八》描绘了工艺的学习，代表着技巧。", upright: "工艺、学习、技巧", reversed: "缺乏技能、骄傲", easternWisdom: "金币八与道家'技近乎道'相契合，提醒我们在技艺中精进。", keywords: ["工艺", "学习", "技巧"] },
        { name: "Nine of Pentacles", description: "《金币九》描绘了独立的女性，代表着物质成功。", upright: "独立、物质成功", reversed: "依赖、财务不稳", easternWisdom: "金币九与易经'大畜'卦相契合，代表着物质积累的成功。", keywords: ["独立", "成功", "物质"] },
        { name: "Ten of Pentacles", description: "《金币十》描绘了财富的场景，代表着家庭成功。", upright: "财富、继承、家庭成功", reversed: "财务损失、家庭问题", easternWisdom: "金币十与儒家'齐家'相契合，代表着家庭和财富的双重成功。", keywords: ["财富", "继承", "家庭"] },
        { name: "Page of Pentacles", description: "《金币宫廷》描绘了年轻的学习者，代表着新机会。", upright: "新机会、学习", reversed: "拖延、错误", easternWisdom: "金币侍从与佛教'学而不厌'相契合，代表着学习和成长的开始。", keywords: ["学习", "新机会", "成长"] },
        { name: "Knight of Pentacles", description: "《金币骑士》描绘了勤奋的工作者，代表着耐心。", upright: "耐心、责任、工作", reversed: "懒惰、迟缓", easternWisdom: "金币骑士与道家'务实'相契合，代表着脚踏实地的努力。", keywords: ["勤奋", "耐心", "工作"] },
        { name: "Queen of Pentacles", description: "《金币女王》描绘了实际的女性，代表着丰盛。", upright: "实际、稳定、丰盛", reversed: "浪费、依赖", easternWisdom: "金币女王与易经'坤'卦相契合，代表着大地的丰盛。", keywords: ["实际", "稳定", "丰盛"] },
        { name: "King of Pentacles", description: "《金币国王》描绘了成功的商人，代表着物质主义大师。", upright: "商业成功、物质主义大师", reversed: "物质主义、贪婪", easternWisdom: "金币国王与道家'知足不辱'相契合，提醒我们在成功中保持知足。", keywords: ["成功", "商业", "知足"] }
