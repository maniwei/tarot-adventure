        { name: "Knight of Cups", description: "《圣杯骑士》描绘了浪漫的骑士，代表着情感的推动。", upright: "浪漫、创意推动", reversed: "幻想、失望", easternWisdom: "圣杯骑士与道家'情动'相契合，代表着浪漫的情感流动。", keywords: ["浪漫", "创意", "推动"] },
        { name: "Queen of Cups", description: "《圣杯女王》描绘了情感成熟的女性，代表着直觉和包容。", upright: "情感成熟、直觉", reversed: "情感依赖、脆弱", easternWisdom: "圣杯女王与易经'坤'卦相契合，代表着包容和养育的阴性力量。", keywords: ["成熟", "直觉", "包容"] },
        { name: "King of Cups", description: "《圣杯国王》描绘了情感平衡的领袖，代表着智慧。", upright: "情感平衡、智慧", reversed: "情感操纵、冷漠", easternWisdom: "圣杯国王与儒家'中和'相契合，代表着情感智慧的成熟。", keywords: ["平衡", "智慧", "成熟"] }
