        { name: "Two of Swords", description: "《宝剑二》描绘了困难的选择，代表着推迟决定。", upright: "困难选择、推迟决定", reversed: "无法决定、信息过载", easternWisdom: "宝剑二与易经'屯'卦相契合，提醒我们在困难中做出选择。", keywords: ["选择", "困难", "推迟"] },
        { name: "Three of Swords", description: "《宝剑三》描绘了心碎的象征，代表着悲伤和释放。", upright: "心碎、悲伤、释放", reversed: "治愈、恢复", easternWisdom: "宝剑三与佛教'无常'相契合，接受悲伤并走向疗愈。", keywords: ["心碎", "悲伤", "释放"] },
        { name: "Four of Swords", description: "《宝剑四》描绘了休息的场景，代表着恢复和和平。", upright: "休息、恢复、和平", reversed: "焦虑、无法休息", easternWisdom: "宝剑四与道家'静'相契合，代表着休息和恢复的力量。", keywords: ["休息", "恢复", "和平"] },
        { name: "Five of Swords", description: "《宝剑五》描绘了冲突，代表着胜利和骄傲。", upright: "冲突、胜利、骄傲", reversed: "修复、宽恕", easternWisdom: "宝剑五与易经'讼'卦相契合，提醒我们在冲突中寻求和平。", keywords: ["冲突", "胜利", "骄傲"] },
        { name: "Six of Swords", description: "《宝剑六》描绘了过渡的场景，代表着改变和疗愈。", upright: "过渡、改变、疗愈", reversed: "停滞、无法前进", easternWisdom: "宝剑六与易经'渐'卦相契合，代表着逐渐过渡的疗愈之路。", keywords: ["过渡", "改变", "疗愈"] },
        { name: "Seven of Swords", description: "《宝剑七》描绘了隐秘的行动，代表着战略和计划。", upright: "战略、计划、隐秘", reversed: "内疚、承认", easternWisdom: "宝剑七与道家'诡道'相契合，提醒我们在计谋中保持正直。", keywords: ["战略", "计划", "隐秘"] },
        { name: "Eight of Swords", description: "《宝剑八》描绘了受限的场景，代表着限制和受害者心态。", upright: "限制、困住、受害者心态", reversed: "释放、自由", easternWisdom: "宝剑八与佛教'我执'相契合，提醒我们突破自我设限。", keywords: ["限制", "被困", "受害者"] },
        { name: "Nine of Swords", description: "《宝剑九》描绘了噩梦的场景，代表着焦虑和恐惧。", upright: "焦虑、恐惧、噩梦", reversed: "面对恐惧", easternWisdom: "宝剑九与道家'心斋'相契合，提醒我们面对内心的恐惧。", keywords: ["焦虑", "恐惧", "噩梦"] },
        { name: "Ten of Swords", description: "《宝剑十》描绘了痛苦的结束，代表着背叛和终点。", upright: "痛苦结束、背叛", reversed: "治愈、恢复", easternWisdom: "宝剑十与佛教'置之死地而后生'相契合，提醒我们痛极思变。", keywords: ["痛苦", "背叛", "终点"] },
        { name: "Page of Swords", description: "《宝剑宫廷》描绘了年轻的信使，代表着信息和真理。", upright: "信息、好奇、真理", reversed: "误解、信息不准确", easternWisdom: "宝剑侍从与佛教'闻思修'相契合，代表着追求真理的过程。", keywords: ["信息", "好奇", "真理"] },
        { name: "Knight of Swords", description: "《宝剑骑士》描绘了激进追求真相的骑士。", upright: "激进、真相追求", reversed: "攻击性、欺骗", easternWisdom: "宝剑骑士与儒家'杀身成仁'相契合，提醒我们在追求真相时保持理性。", keywords: ["激进", "追求", "真相"] },
        { name: "Queen of Swords", description: "《宝剑女王》描绘了智慧独立的女性，代表着清晰和批判。", upright: "清晰、智慧、独立", reversed: "冷漠、批判", easternWisdom: "宝剑女王与易经'兑'卦相契合，代表着智慧的清晰表达。", keywords: ["清晰", "智慧", "独立"] },
        { name: "King of Swords", description: "《宝剑国王》描绘了权威的统治者，代表着理性和权威。", upright: "权威、理性、真理", reversed: "暴政、滥用权力", easternWisdom: "宝剑国王与道家'太上'相契合，提醒我们权力需要仁慈驾驭。", keywords: ["权威", "理性", "真理"] }
